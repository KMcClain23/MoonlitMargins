# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Resend (application + status notification emails)
RESEND_API_KEY=
RESEND_FROM_EMAIL=
NOTIFY_EMAIL=

# Admin panel (cookie-based auth, same pattern as the Reinita site)
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=

# Cloudflare R2 (member photos, memories gallery)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# YouTube Data API v3 (optional -- pulls each YouTube memory's real
# description and upload date; without this, only the title auto-fills,
# via oEmbed, which needs no key)
YOUTUBE_API_KEY=
